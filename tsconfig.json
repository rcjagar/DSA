{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "noEmitOnError": true
  },
  "include": ["**/*.ts", "Chapter01/GetSum/GetSum-run.js", "Chapter01/ReversingString/ReversingString-run.js"],
  "exclude": ["node_modules", "dist"]
}
